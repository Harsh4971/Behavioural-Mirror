{
  "manifest_version": 3,
  "name": "Mirror: Voice Insights",
  "key": "",
  "short_name": "Mirror",
  "version": "1.0.0",
  "description": "Record Google Meet calls or upload audio to get AI-powered communication insights. Track filler words, talk ratio, speech pace, and 15+ behavioral signals. Builds a personal profile of how you communicate across different contexts over time.",
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Mirror: Voice Insights",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "identity", "activeTab", "tabs", "tabCapture", "offscreen", "sidePanel"],
  "host_permissions": [
    "https://harsh200415-mirror-backend.hf.space/*",
    "https://dqxajifqeegeisgqnjqs.supabase.co/*",
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meet-webrtc-injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content-meet.js"],
      "run_at": "document_idle"
    }
  ]
}
